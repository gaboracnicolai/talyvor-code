node_modules/
out/
*.js.map
dist/
*.vsix

# Local secrets — the CLI reads TALYVOR_* from .env. Never commit
# a real one; .env.example is the tracked template.
.env
.env.*
!.env.example

# JetBrains Gradle build outputs (the wrapper jar is generated
# by `gradle wrapper` on first build — see jetbrains/README.md).
jetbrains/.gradle/
jetbrains/build/
jetbrains/gradle/wrapper/gradle-wrapper.jar
jetbrains/gradlew
jetbrains/gradlew.bat
jetbrains/.idea/
# IntelliJ Platform Gradle Plugin 2.x local cache (self-update lock +
# resolved local platform artifacts). Generated on first build.
jetbrains/.intellijPlatform/

# Talyvor Code semantic index cache (generated by `talyvor-code index`)
.talyvor/
