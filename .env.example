# Talyvor Code — environment variables. Copy to `.env` and fill
# in. The CLI agent reads these at startup; the VS Code extension
# uses the equivalent talyvor.* settings instead.

# ─── Talyvor Lens (required for AI features) ─────────
# Hosted: TALYVOR_LENS_URL=https://lens.talyvor.com
# Remote URLs must be https — the CLI refuses to send the API key
# over cleartext http to any non-localhost host.
TALYVOR_LENS_URL=http://localhost:8080
TALYVOR_LENS_API_KEY=tlv_...

# ─── Talyvor Track (optional, for issue attribution) ─
# Without these, AI calls still work — they just won't be
# attributed to a Track issue.
TALYVOR_TRACK_URL=http://localhost:3000
TALYVOR_TRACK_API_KEY=
TALYVOR_WORKSPACE_ID=
TALYVOR_ISSUE=

# ─── Talyvor Docs (optional, for spec integration) ───
# When set, the hover provider + DocsPanel + spec-watcher come
# online inside the VS Code extension and `talyvor-code docs`
# subcommands gain access to your docs.
TALYVOR_DOCS_URL=http://localhost:4000
TALYVOR_DOCS_API_KEY=

# ─── Model selection ─────────────────────────────────
# Haiku for fast completions; switch to Sonnet for higher-quality
# chat and test generation if cost permits.
TALYVOR_MODEL=claude-haiku-4-5
